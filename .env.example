# Insight Engine — environment template
# Copy to `.env` and fill in only what you have. Everything is optional:
# missing values disable the corresponding feature, they never crash the run.

# --- Data ---
USE_LIVE_DATA=false             # true → fetch live OHLCV via yfinance (needs internet)
CACHE_PATH=app/data/snapshot.json
FRED_API_KEY=                   # optional macro indicators

# --- Analysis ---
FORECAST_HORIZON_DAYS=30
MAPE_THRESHOLD=15.0             # critique loops back above this
RISK_FREE_RATE=0.04            # annualized, decimal, for Sharpe
USE_MATLAB=false               # true → MATLAB wavelet hook (needs licensed MATLAB)

# --- Distribution / MCP (all optional) ---
ENVIRONMENT=development         # development blocks gmail_send & calendar_create
GMAIL_RECIPIENT=                # set to enable Gmail channel
DRIVE_FOLDER=                   # set to enable Drive destination
CHAT_ENABLED=false             # true → enable Chat notification channel

# --- Storage ---
DB_PATH=artifacts/history.db
REPORTS_DIR=artifacts/reports
CHARTS_DIR=artifacts/charts
